<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>3PL Miami Warehousing — Capabilities</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Archivo+Expanded:wght@600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap');

  :root {
    --ink: #0A0E1A;
    --ink-2: #141B2E;
    --paper: #F5F3EE;
    --paper-2: #EAE7DE;
    --signal: #FF4D2E;      /* hot signal orange-red */
    --signal-dim: #E8371A;
    --cyan: #14E0C8;        /* electric teal accent */
    --steel: #7C8698;
    --steel-light: #A8B0BE;
    --line: rgba(255,255,255,0.10);
    --line-dark: rgba(10,14,26,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--ink);
    color: var(--paper);
    font-family: 'Archivo', sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  ::selection { background: var(--signal); color: #fff; }

  .mono { font-family: 'JetBrains Mono', monospace; }

  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }

  /* ---------- GRID BACKDROP ---------- */
  .grid-bg {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 0%, #000 40%, transparent 100%);
    opacity: 0.5;
  }

  /* ---------- NAV ---------- */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10,14,26,0.72);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  nav .wrap { display: flex; align-items: center; justify-content: space-between; height: 68px; }
  .brand { display: flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: -0.02em; font-size: 16px; }
  .brand .dot { width: 10px; height: 10px; background: var(--signal); border-radius: 2px; box-shadow: 0 0 14px var(--signal); }
  .nav-links { display: flex; gap: 34px; }
  .nav-links a { color: var(--steel-light); text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 0.01em; transition: color 0.2s; }
  .nav-links a:hover { color: var(--paper); }
  .nav-cta { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink); background: var(--cyan); padding: 9px 16px; border-radius: 4px; font-weight: 700; text-decoration: none; letter-spacing: 0.02em; }
  @media (max-width: 820px){ .nav-links { display: none; } }

  /* ---------- HERO ---------- */
  header { position: relative; z-index: 1; padding: 150px 0 90px; }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--signal); margin-bottom: 28px;
    display: flex; align-items: center; gap: 14px;
  }
  .eyebrow::before { content: ''; width: 42px; height: 1px; background: var(--signal); display: inline-block; }

  h1.hero {
    font-family: 'Archivo Expanded', 'Archivo', sans-serif;
    font-weight: 900; font-size: clamp(44px, 8vw, 108px);
    line-height: 0.92; letter-spacing: -0.03em; text-transform: uppercase;
  }
  h1.hero .out { -webkit-text-stroke: 1.5px var(--steel-light); color: transparent; }
  h1.hero .sig { color: var(--signal); }

  .hero-sub {
    margin-top: 34px; max-width: 640px; font-size: clamp(16px, 2vw, 20px);
    line-height: 1.55; color: var(--steel-light); font-weight: 400;
  }
  .hero-sub b { color: var(--paper); font-weight: 600; }

  .hero-actions { margin-top: 44px; display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { background: var(--signal); color: #fff; padding: 15px 30px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 15px; letter-spacing: 0.01em; transition: transform 0.15s, box-shadow 0.2s; box-shadow: 0 8px 30px rgba(255,77,46,0.3); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(255,77,46,0.45); }
  .btn-ghost { border: 1px solid var(--line); color: var(--paper); padding: 15px 30px; border-radius: 5px; font-weight: 600; text-decoration: none; font-size: 15px; transition: border-color 0.2s, background 0.2s; }
  .btn-ghost:hover { border-color: var(--steel-light); background: rgba(255,255,255,0.03); }

  /* ---------- STAT STRIP ---------- */
  .strip {
    position: relative; z-index: 1; margin-top: 80px;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .strip .wrap { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat { padding: 34px 24px; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: none; }
  .stat .num { font-family: 'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: clamp(30px, 4vw, 46px); letter-spacing: -0.02em; line-height: 1; }
  .stat .num .u { color: var(--signal); }
  .stat .lbl { margin-top: 10px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--steel); line-height: 1.5; }
  @media (max-width: 820px){ .strip .wrap { grid-template-columns: repeat(2, 1fr); } .stat:nth-child(2){ border-right: none; } .stat:nth-child(1),.stat:nth-child(2){ border-bottom: 1px solid var(--line);} }

  /* ---------- SECTION SHELL ---------- */
  section { position: relative; z-index: 1; padding: 100px 0; }
  .sec-head { display: flex; align-items: baseline; gap: 20px; margin-bottom: 54px; }
  .sec-tag { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--signal); font-weight: 700; letter-spacing: 0.05em; }
  .sec-title { font-family: 'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.02em; text-transform: uppercase; line-height: 1; }
  .sec-intro { max-width: 620px; color: var(--steel-light); font-size: 17px; line-height: 1.6; margin-top: 18px; }

  /* ---------- PARTNERSHIP SPLIT ---------- */
  .partner-section { background: var(--ink-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .split { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0; align-items: stretch; margin-top: 10px; }
  .split-col { padding: 40px; }
  .split-col h3 { font-family:'Archivo Expanded','Archivo',sans-serif; font-size: 22px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 8px; }
  .split-col .who { font-family:'JetBrains Mono',monospace; font-size: 12px; color: var(--steel); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 20px; }
  .split-col p { color: var(--steel-light); line-height: 1.6; font-size: 15px; }
  .split-col.them h3 { color: var(--cyan); }
  .split-col.us h3 { color: var(--signal); }
  .split-mid { display: flex; align-items: center; justify-content: center; padding: 0 8px; position: relative; }
  .split-mid .x { font-family:'Archivo Expanded',sans-serif; font-weight: 900; font-size: 40px; color: var(--paper); opacity: 0.25; }
  .flow-note { margin-top: 36px; padding: 26px 30px; border: 1px dashed rgba(20,224,200,0.4); border-radius: 8px; background: rgba(20,224,200,0.04); display: flex; gap: 18px; align-items: center; }
  .flow-note .arw { font-size: 22px; color: var(--cyan); }
  .flow-note p { color: var(--paper); font-size: 15px; line-height: 1.55; }
  .flow-note b { color: var(--cyan); }
  @media (max-width: 820px){ .split { grid-template-columns: 1fr; } .split-mid { padding: 14px; } .split-mid .x { font-size: 28px; } }

  /* ---------- FACILITIES ---------- */
  .fac-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; }
  .fac {
    border: 1px solid var(--line-dark); border-radius: 10px; padding: 30px;
    background: var(--paper); color: var(--ink); position: relative; overflow: hidden;
    display: flex; flex-direction: column; min-height: 230px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .fac:hover { transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
  .fac .idx { font-family:'JetBrains Mono',monospace; font-size: 12px; color: var(--signal); font-weight: 700; letter-spacing: 0.1em; }
  .fac .sqft { font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 900; font-size: 46px; letter-spacing: -0.03em; line-height: 0.95; margin-top: 14px; }
  .fac .sqft span { font-size: 18px; color: var(--steel); font-weight: 700; }
  .fac .fname { margin-top: 6px; font-weight: 700; font-size: 15px; letter-spacing: -0.01em; }
  .fac .fdesc { margin-top: 12px; font-size: 13.5px; line-height: 1.5; color: #4A5262; flex-grow: 1; }
  .fac .tags { margin-top: 16px; display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { font-family:'JetBrains Mono',monospace; font-size: 10px; font-weight: 500; letter-spacing: 0.04em; padding: 4px 8px; border-radius: 3px; background: var(--paper-2); color: var(--ink-2); }
  .tag.hot { background: var(--ink); color: var(--cyan); }
  .tag.soon { background: transparent; border: 1px dashed var(--steel-light); color: var(--steel); }
  .fac .badge { position: absolute; top: 22px; right: 22px; font-family:'JetBrains Mono',monospace; font-size: 9px; font-weight: 700; letter-spacing: 0.08em; padding: 4px 8px; border-radius: 20px; text-transform: uppercase; }
  .badge.flagship { background: var(--signal); color: #fff; }
  .badge.new { background: var(--cyan); color: var(--ink); }

  /* span helpers */
  .c12 { grid-column: span 12; } .c6 { grid-column: span 6; } .c4 { grid-column: span 4; } .c8 { grid-column: span 8; }
  @media (max-width: 820px){ .c12,.c6,.c4,.c8 { grid-column: span 12; } }

  .flagship-fac { background: var(--ink); color: var(--paper); border-color: var(--line); }
  .flagship-fac .sqft { color: var(--paper); }
  .flagship-fac .fdesc { color: var(--steel-light); }
  .flagship-fac .fname { color: var(--paper); }

  /* ---------- EXPANSION CALLOUT ---------- */
  .expand {
    margin-top: 20px; grid-column: span 12; border-radius: 10px; padding: 32px 36px;
    background: linear-gradient(100deg, var(--signal) 0%, var(--signal-dim) 100%);
    color: #fff; display: flex; align-items: center; justify-content: space-between; gap: 30px; flex-wrap: wrap;
  }
  .expand h4 { font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: 24px; text-transform: uppercase; letter-spacing: -0.01em; }
  .expand p { margin-top: 8px; font-size: 15px; line-height: 1.5; max-width: 620px; opacity: 0.95; }
  .expand .big { font-family:'Archivo Expanded',sans-serif; font-weight: 900; font-size: 60px; line-height: 1; letter-spacing: -0.03em; white-space: nowrap; }

  /* ---------- CAPABILITIES / SERVICE ---------- */
  .cap-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .cap {
    border: 1px solid var(--line); border-radius: 10px; padding: 30px;
    background: rgba(255,255,255,0.02); transition: background 0.2s, border-color 0.2s;
  }
  .cap:hover { background: rgba(255,255,255,0.045); border-color: rgba(255,255,255,0.2); }
  .cap .ico { width: 40px; height: 40px; border-radius: 8px; background: rgba(255,77,46,0.12); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
  .cap .ico svg { width: 20px; height: 20px; stroke: var(--signal); fill: none; stroke-width: 2; }
  .cap h4 { font-size: 17px; font-weight: 700; letter-spacing: -0.01em; margin-bottom: 10px; }
  .cap p { font-size: 14px; line-height: 1.55; color: var(--steel-light); }
  @media (max-width: 820px){ .cap-grid { grid-template-columns: 1fr; } }

  /* ---------- SOFTWARE FEATURE ---------- */
  .soft { background: var(--ink-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .soft-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .soft-copy h2 { font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: clamp(28px,4vw,42px); text-transform: uppercase; letter-spacing: -0.02em; line-height: 1; margin-bottom: 20px; }
  .soft-copy h2 .em { color: var(--cyan); }
  .soft-copy > p { color: var(--steel-light); font-size: 16px; line-height: 1.6; margin-bottom: 28px; }
  .soft-list { display: flex; flex-direction: column; gap: 14px; }
  .soft-item { display: flex; gap: 14px; align-items: flex-start; }
  .soft-item .k { color: var(--cyan); font-family:'JetBrains Mono',monospace; font-size: 13px; font-weight: 700; margin-top: 2px; }
  .soft-item p { font-size: 14.5px; line-height: 1.5; color: var(--paper); }
  .soft-item p b { color: var(--paper); }

  /* protection band */
  .protect { }
  .protect-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 4px; }
  .pcard { border: 1px solid var(--line); border-radius: 10px; padding: 26px; background: rgba(255,255,255,0.02); }
  .pcard .pk { font-family:'JetBrains Mono',monospace; font-size: 11px; color: var(--cyan); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .pcard h4 { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; margin-bottom: 8px; }
  .pcard p { font-size: 13.5px; line-height: 1.55; color: var(--steel-light); }
  @media (max-width: 820px){ .protect-grid { grid-template-columns: 1fr; } }

  /* software feature panel */
  .soft-panel { border: 1px solid var(--line); border-radius: 12px; background: var(--ink); overflow: hidden; box-shadow: 0 30px 80px rgba(0,0,0,0.5); }
  .sp-head { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--line); background: rgba(255,255,255,0.02); }
  .sp-mark { font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: 15px; letter-spacing: 0.02em; color: var(--cyan); }
  .sp-tag { font-family:'JetBrains Mono',monospace; font-size: 10px; color: var(--steel); letter-spacing: 0.1em; }
  .sp-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .sp-cell { padding: 16px 18px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .sp-cell:nth-child(even){ border-right: none; }
  .sp-k { font-size: 13px; font-weight: 700; color: var(--paper); letter-spacing: -0.01em; }
  .sp-v { margin-top: 4px; font-family:'JetBrains Mono',monospace; font-size: 10.5px; color: var(--steel); letter-spacing: 0.01em; }
  .sp-foot { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; }
  .sp-live { display: inline-flex; align-items: center; gap: 8px; font-family:'JetBrains Mono',monospace; font-size: 10px; color: #28C840; letter-spacing: 0.08em; }
  .sp-live .pulse { width: 6px; height: 6px; border-radius: 50%; background: #28C840; animation: pulse 1.6s infinite; }
  .sp-assist { font-family:'JetBrains Mono',monospace; font-size: 10px; color: var(--cyan); letter-spacing: 0.05em; }
  @keyframes pulse { 0%,100%{ opacity: 1; } 50%{ opacity: 0.3; } }
  @media (max-width: 820px){ .soft-inner { grid-template-columns: 1fr; gap: 40px; } }

  /* ---------- SERVICE ETHOS ---------- */
  .ethos-quote {
    font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 700;
    font-size: clamp(24px, 3.4vw, 40px); line-height: 1.2; letter-spacing: -0.02em;
    max-width: 960px;
  }
  .ethos-quote .hl { color: var(--signal); }
  .ethos-sub { margin-top: 30px; max-width: 640px; color: var(--steel-light); font-size: 16px; line-height: 1.65; }

  /* ---------- CERTS ---------- */
  .cert-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 10px; }
  .cert {
    font-family:'JetBrains Mono',monospace; font-size: 13px; font-weight: 500;
    padding: 12px 20px; border: 1px solid var(--line); border-radius: 6px;
    display: flex; align-items: center; gap: 10px; letter-spacing: 0.02em;
  }
  .cert::before { content:''; width: 7px; height: 7px; background: var(--cyan); border-radius: 50%; }

  /* ---------- CLIENTS ---------- */
  .clients { }
  .client-strip { display: flex; flex-wrap: wrap; gap: 0; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
  .client {
    flex: 1 1 20%; min-width: 150px; padding: 34px 20px; text-align: center;
    font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 800; font-size: 17px;
    letter-spacing: 0.01em; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line);
    color: var(--paper); transition: background 0.2s, color 0.2s; text-transform: uppercase;
  }
  .client:hover { background: var(--signal); color: #fff; }

  /* ---------- CTA ---------- */
  .cta-final { text-align: center; padding: 130px 0; }
  .cta-final h2 { font-family:'Archivo Expanded','Archivo',sans-serif; font-weight: 900; font-size: clamp(34px, 6vw, 76px); text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.95; }
  .cta-final h2 .out { -webkit-text-stroke: 1.5px var(--signal); color: transparent; }
  .cta-final p { margin: 28px auto 40px; max-width: 520px; color: var(--steel-light); font-size: 18px; line-height: 1.55; }
  .cta-contact { display: flex; gap: 40px; justify-content: center; flex-wrap: wrap; margin-top: 50px; }
  .cta-contact .item { text-align: left; }
  .cta-contact .k { font-family:'JetBrains Mono',monospace; font-size: 11px; color: var(--steel); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
  .cta-contact .v { font-size: 16px; font-weight: 600; }

  /* ---------- FOOTER ---------- */
  footer { border-top: 1px solid var(--line); padding: 40px 0; position: relative; z-index: 1; }
  footer .wrap { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  footer .fbrand { font-weight: 800; letter-spacing: -0.01em; }
  footer .fmeta { font-family:'JetBrains Mono',monospace; font-size: 12px; color: var(--steel); }

  /* reveal anim */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(.2,.7,.3,1), transform 0.7s cubic-bezier(.2,.7,.3,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce){ .reveal { opacity: 1; transform: none; transition: none; } .sp-live .pulse { animation: none; } }
</style>
</head>
<body>

<div class="grid-bg"></div>

<nav>
  <div class="wrap">
    <div class="brand"><span class="dot"></span> 3PL MIAMI WAREHOUSING</div>
    <div class="nav-links">
      <a href="#network">Network</a>
      <a href="#capabilities">Capabilities</a>
      <a href="#software">Software</a>
      <a href="#clients">Clients</a>
    </div>
    <a href="#contact" class="nav-cta">GET IN TOUCH</a>
  </div>
</nav>

<header>
  <div class="wrap">
    <div class="eyebrow">Capabilities Brief — South Florida</div>
    <h1 class="hero">
      Warehousing<br>
      <span class="out">without the</span><br>
      <span class="sig">friction.</span>
    </h1>
    <p class="hero-sub">
      A full-service warehousing and distribution operation built for high-volume, fast-moving brands.
      <b>400,000+ square feet</b> across five South Florida facilities — engineered, certified, and constantly expanding to fit whatever a client needs to move.
    </p>
    <div class="hero-actions">
      <a href="#network" class="btn-primary">See the network</a>
      <a href="#capabilities" class="btn-ghost">What we handle</a>
    </div>
  </div>
</header>

<div class="strip reveal">
  <div class="wrap">
    <div class="stat"><div class="num">400K<span class="u">+</span></div><div class="lbl">Sq Ft // 5 Facilities</div></div>
    <div class="stat"><div class="num">24<span class="u">HR</span></div><div class="lbl">Receive → Ship Standard</div></div>
    <div class="stat"><div class="num">72<span class="u">°</span></div><div class="lbl">Climate-Controlled Zones</div></div>
    <div class="stat"><div class="num">FULL</div><div class="lbl">FTZ · Liquor · Tobacco · Food</div></div>
  </div>
</div>

<!-- NETWORK / FACILITIES -->
<section id="network">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-tag">01</span>
      <div>
        <div class="sec-title">The Network</div>
        <p class="sec-intro">Five active South Florida facilities and growing — each purpose-fit, from our flagship smart warehouse to newly acquired temperature-controlled space coming fully certified within months.</p>
      </div>
    </div>

    <div class="fac-grid">
      <!-- Flagship -->
      <div class="fac flagship-fac c8 reveal">
        <span class="badge flagship">Flagship HQ</span>
        <span class="idx">FACILITY 01 — MEDLEY HQ</span>
        <div class="sqft">100K <span>SQ FT</span></div>
        <div class="fname">Smart Warehouse — Maximum Density</div>
        <div class="fdesc">Our most capable facility. Space-optimizing smart-warehouse system for the highest pallet-per-square-foot utilization in the network. Fully certified, with a dedicated 5,000 sq ft zone held at a precise 72°F for temperature-sensitive product.</div>
        <div class="tags">
          <span class="tag hot">72° TEMP ZONE</span>
          <span class="tag">FTZ</span><span class="tag">LIQUOR</span><span class="tag">TOBACCO</span><span class="tag">FOOD GRADE</span>
        </div>
      </div>

      <!-- Loc 2 -->
      <div class="fac c4 reveal">
        <span class="idx">FACILITY 02</span>
        <div class="sqft">175K <span>SQ FT</span></div>
        <div class="fname">Dry Storage</div>
        <div class="fdesc">High-capacity dry storage. Built for volume and heavy freight across bulk consumer and industrial goods.</div>
        <div class="tags"><span class="tag">DRY STORAGE</span><span class="tag">HIGH VOLUME</span></div>
      </div>

      <!-- Loc 3 -->
      <div class="fac c4 reveal">
        <span class="badge new">New</span>
